//// final inventory
SELECT 
DISTINCT w.name as warehouse_name, bn.name as bin_name,mb.b_shortname, ms.stl_no, moe.order_code,
mci.item_name, mci.ref_item,
mmc.clr_name, mmc.clr_addt_name, ma.art_name, fcr.roll_no, fcr.sup_roll_no as 'supplier roll no', si.qty, 
si.remaining_qty,
CASE 
	-- WHEN si.roll_stage IN (1,99) THEN 'Inventory'
	WHEN si.roll_stage = 2 THEN 'Stock'
	WHEN si.roll_stage = 3 THEN 'Leftover'
	ELSE 'Inventory' 
	END as 'stage',
gi.package 
-- sum(si.remaining_qty)
FROM mbm_store_inventory.fabric_color_rolls AS fcr
join mbm_store_inventory.st_inventory si on fcr.roll_no = si.roll
left join mbm_store_inventory.gate_in gi on fcr.gi_id = gi.id
left join cuttingedgedb.mr_order_entry moe on fcr.order_id = moe.order_id
left join cuttingedgedb.mr_buyer mb on moe.mr_buyer_b_id = mb.b_id
left join cuttingedgedb.mr_style ms on moe.mr_style_stl_id = ms.stl_id
left join cuttingedgedb.mr_material_color mmc on si.clr_id = mmc.clr_id
left join cuttingedgedb.mr_cat_item mci on si.item_id = mci.id
LEFT JOIN cuttingedgedb.mr_article AS ma
    ON si.art_id = ma.id
LEFT JOIN mbm_store_inventory.st_bin AS bn
    ON bn.id = fcr.bin_id
LEFT JOIN mbm_store_inventory.st_warehouse AS w
    ON w.id = COALESCE(
        NULLIF(fcr.warehouse_id, 0),
        bn.warehouse_id
    )

WHERE si.unit_id = 2 
and fcr.unit_id = 2 
and si.roll IS NOT NULL 
and si.remaining_qty > 0 
-- and (si.roll_stage = 1 OR si.roll_stage = 99) 
and fcr.relaxation_status != 2
and fcr.roll_type IN (1,2, 3)
